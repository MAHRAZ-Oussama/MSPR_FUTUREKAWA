# ──────────────────────────────────────────────────────────────────────────────
# FutureKawa — exemple de configuration
# Copier en `.env` et adapter. En Docker Compose, ces valeurs sont déjà fournies
# par service ; ce fichier documente l'ensemble des variables disponibles.
# ──────────────────────────────────────────────────────────────────────────────

# ── Backend pays (api-br / api-ec / api-co) ──────────────────────────────────
COUNTRY=BR
DATABASE_URL=postgresql+asyncpg://futurekawa:futurekawa@postgres-br:5432/futurekawa

# SMTP pour l'envoi des emails d'alerte (MailHog en dev)
SMTP_HOST=mailhog
SMTP_PORT=1025
ALERT_SENDER=alertes@futurekawa.com

# Règles métier
EXPIRY_DAYS=365              # un lot au-delà devient PERIME + alerte LOT_EXPIRED
FLOOD_WINDOW_MINUTES=30      # fenêtre de déduplication anti-flood des alertes
CHECK_INTERVAL_MINUTES=5     # période de la tâche de vérification automatique

# Sécurité (laisser vide = ouvert, pour la démo)
API_KEY=                     # si défini, exigé (header X-API-Key) sur les écritures
CORS_ORIGINS=*               # ex. http://localhost:8080 pour restreindre

# ── Subscriber MQTT (subscriber-br / -ec / -co) ──────────────────────────────
MQTT_HOST=mosquitto-br
MQTT_PORT=1883

# ── Simulateur IoT (simulator-br / -ec / -co) ────────────────────────────────
INTERVAL_S=30

# ── Backend central (siège) ──────────────────────────────────────────────────
URL_BR=http://api-br:8000
URL_EC=http://api-ec:8000
URL_CO=http://api-co:8000
